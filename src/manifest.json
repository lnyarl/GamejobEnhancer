{
  "manifest_version": 3,
  "name": "Gamejob Enhancer",
  "version": "0.1.0",
  "description": "Modernize gamejob.co.kr UI/UX",
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "host_permissions": ["https://www.gamejob.co.kr/*"],
  "permissions": ["storage"],
  "icons": {
    "16": "src/icons/icon.png",
    "48": "src/icons/icon.png",
    "128": "src/icons/icon.png"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.gamejob.co.kr/*"],
      "js": ["src/content/index.ts"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["https://www.gamejob.co.kr/*"],
      "js": ["src/content/alert-patch-main.ts"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    }
  ]
}
