{
  "manifest_version": 3,
  "name": "Gamejob Enhancer",
  "version": "0.1.0",
  "description": "Modernize gamejob.co.kr UI/UX",
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "host_permissions": ["https://www.gamejob.co.kr/*"],
  "permissions": ["storage"],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.gamejob.co.kr/*"],
      "js": ["src/content/index.ts"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
